# Copy to `.env` and adjust. CRA reads this at build/dev start.
#
# Cloud Run / full API base (no trailing slash). Include `/api` if your server uses that prefix.
# REACT_APP_API_BASE=https://your-service-xxxxx.run.app/api
#
# CORS on the backend (required because the app uses fetch(..., credentials: 'include')):
# - Access-Control-Allow-Origin: exact frontend origin (NOT *), e.g.
#     http://localhost:3000
#     https://dario1899.github.io
# - Access-Control-Allow-Credentials: true
# - Allow methods/headers your API needs (e.g. POST, Authorization, Content-Type)
